modules = ["bash", "nix"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash setup_and_build.sh"

[userenv]

[userenv.shared]
KEYSTORE_PATH = "androidApp/keystore/gainznote-release.jks"
KEY_ALIAS = "GainzNote-key"
STORE_PASSWORD = "gainznote_store_2024"
KEY_PASSWORD = "gainznote_store_2024"
